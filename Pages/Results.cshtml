@page
@model ResultsModel
@{
    ViewData["Title"] = "Analysis Results";
}

@if (Model?.Analysis != null)
{
    <div class="results-header">
        <h2>Your Career Assessment for <strong>@Model.TargetRole</strong></h2>
        <p class="results-summary">This report is based on your resume content and the expectations for the role you entered. Use it to focus on the highest-impact gaps and opportunities.</p>
    </div>

    <!-- Score Card -->
    <div class="score-card">
        <div class="score-display">
            <div class="score-number @Model.GetScoreClass()">@Model.Analysis.Score</div>
            <div class="score-label">Readiness Score</div>
            <p class="score-interpretation">@Model.GetScoreInterpretation()</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Analysis.QuickSummary))
    {
        <section class="card quick-summary-section">
            <h3>⚡ Quick Summary</h3>
            <ul class="summary-list">
                @foreach (var line in Model.Analysis.QuickSummary.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                {
                    <li>@line.Trim()</li>
                }
            </ul>
        </section>
    }

    @if (Model.Analysis.QuickWins?.Count > 0)
    {
        <section class="card quick-wins-section">
            <h3>🚀 Quick Wins</h3>
            <ol class="quick-wins-list">
                @foreach (var win in Model.Analysis.QuickWins)
                {
                    <li>@win</li>
                }
            </ol>
        </section>
    }

    @if (Model.Analysis.ResumeTips?.Count > 0)
    {
        <section class="card resume-tips-section">
            <h3>📝 Resume Tips</h3>
            <ul class="summary-list">
                @foreach (var tip in Model.Analysis.ResumeTips)
                {
                    <li>@tip</li>
                }
            </ul>
        </section>
    }

    @if (Model.Analysis.FirstStep != null && !string.IsNullOrWhiteSpace(Model.Analysis.FirstStep.Task))
    {
        <section class="card first-step-hero" aria-labelledby="first-step-heading">
            <h3 id="first-step-heading">🚀 Start Here — this is the fastest way to make progress</h3>
            <p id="first-step-task-text" class="first-step-task-body">@Model.Analysis.FirstStep.Task</p>
            <div class="first-step-meta">
                <p><span class="first-step-meta-label">⏱ Time:</span> @Model.Analysis.FirstStep.Time</p>
                <p><span class="first-step-meta-label">🎯 Outcome:</span> @Model.Analysis.FirstStep.Outcome</p>
            </div>
            <div class="first-step-actions">
                @if (!string.IsNullOrWhiteSpace(Model.Analysis.FirstStep.Resource))
                {
                    <a href="@Model.Analysis.FirstStep.Resource" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Start Step 1</a>
                }
                <button type="button" class="btn btn-outline" onclick="copyFirstStepTask()">Copy</button>
            </div>
            <div class="first-step-micro-feedback" role="group" aria-label="Was this first step helpful?">
                <button type="button" class="btn-micro-feedback" onclick="firstStepMicroFeedback(true)">👍 This makes sense</button>
                <button type="button" class="btn-micro-feedback" onclick="firstStepMicroFeedback(false)">👎 Not useful</button>
            </div>
            <p id="first-step-micro-msg" class="first-step-micro-msg" hidden></p>
        </section>
    }

    <!-- Strengths Section -->
    <section class="card strengths-section">
        <h3>💪 What you're already good at</h3>
        @if (Model.Analysis.Strengths?.Count > 0)
        {
            <ul class="strengths-list">
                @foreach (var strength in Model.Analysis.Strengths)
                {
                    <li>@strength</li>
                }
            </ul>
        }
        else
        {
            <p>No strengths detected. The assessor may not have enough data.</p>
        }
    </section>

    <!-- Missing Skills Section -->
    <section class="card skills-section">
        <h3>🎯 Focus Areas to Improve</h3>
        <div class="skill-blocks">
            @if (Model.Analysis.MissingSkills.MustHave?.Count > 0)
            {
                <div class="skill-priority">
                    <h4 class="priority-label must-have">⚠️ MUST HAVE (Critical)</h4>
                    <ul class="skills-list">
                        @foreach (var missing in Model.Analysis.MissingSkills.MustHave)
                        {
                            <li><span class="skill-badge">@missing.Skill</span></li>
                        }
                    </ul>
                </div>
            }

            @if (Model.Analysis.MissingSkills.GoodToHave?.Count > 0)
            {
                <div class="skill-priority">
                    <h4 class="priority-label good-to-have">✨ GOOD TO HAVE (Next Level)</h4>
                    <ul class="skills-list">
                        @foreach (var missing in Model.Analysis.MissingSkills.GoodToHave)
                        {
                            <li><span class="skill-badge">@missing.Skill</span></li>
                        }
                    </ul>
                </div>
            }
        </div>
    </section>

    <!-- Role Assessment -->
    <section class="card assessment-section">
        <h3>📊 Role Fit Assessment</h3>
        <div class="fit-indicator @Model.GetFitClass()">
            <strong>@Model.GetFitLabel():</strong> @Model.Analysis.RoleAssessment.Fit
        </div>
        @if (!string.IsNullOrEmpty(Model.Analysis.RoleAssessment.SuggestedRole))
        {
            <p><strong>Suggested Role:</strong> @Model.Analysis.RoleAssessment.SuggestedRole</p>
        }
        @if (!string.IsNullOrEmpty(Model.Analysis.RoleAssessment.Confidence))
        {
            <p><strong>Confidence:</strong> @Model.Analysis.RoleAssessment.Confidence</p>
        }
        @if (!string.IsNullOrEmpty(Model.Analysis.RoleAssessment.Reason))
        {
            <p><em>@Model.Analysis.RoleAssessment.Reason</em></p>
        }
    </section>

    <!-- Action Items -->
    <section class="card actions-section">
        <h3>🚀 Your Action Plan</h3>
        @if (Model.Analysis.ActionPlan?.Count > 0)
        {
            <div class="actions-grid">
                @foreach (var (step, ordinal) in Model.Analysis.ActionPlan.Select((s, i) => (s, i + 1)))
                {
                    <div class="action-card">
                        <div class="action-number">@(step.Step >= 1 ? step.Step : ordinal)</div>
                        <h4>@step.Task</h4>
                        <div class="action-meta">
                            <span class="badge difficulty-@Model.DifficultySlug(step.Difficulty)">@step.Difficulty</span>
                            <span class="badge time">⏱️ @step.Time</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(step.Why))
                        {
                            <p class="action-detail"><strong>Why:</strong> @step.Why</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(step.SuccessCriteria))
                        {
                            <p class="action-detail"><strong>Success criteria:</strong> @step.SuccessCriteria</p>
                        }
                        @if (string.IsNullOrWhiteSpace(step.Why) && string.IsNullOrWhiteSpace(step.SuccessCriteria) && !string.IsNullOrWhiteSpace(step.Goal))
                        {
                            <p class="action-detail"><strong>Goal:</strong> @step.Goal</p>
                        }
                    </div>
                }
            </div>
        }
        else if (Model.Analysis.Actions?.Count > 0)
        {
            <div class="actions-grid">
                @foreach (var (action, index) in Model.Analysis.Actions.Select((a, i) => (a, i + 1)))
                {
                    <div class="action-card">
                        <div class="action-number">@index</div>
                        <h4>@action.Task</h4>
                        <div class="action-meta">
                            <span class="badge difficulty-@Model.DifficultySlug(action.Difficulty)">@action.Difficulty</span>
                            <span class="badge time">⏱️ @action.Time</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(action.Why))
                        {
                            <p class="action-detail"><strong>Why:</strong> @action.Why</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(action.SuccessCriteria))
                        {
                            <p class="action-detail"><strong>Success criteria:</strong> @action.SuccessCriteria</p>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <p>No action plan available. Try adjusting the target role or resume detail.</p>
        }
    </section>

    <!-- Feedback Section -->
    <div class="feedback-link">
        <a href="#" onclick="openFeedbackModal(); return false;">💬 Help us improve - Share your feedback</a>
    </div>

    <!-- Feedback Modal -->
    <div id="feedbackModal" class="modal">
        <div class="modal-content">
            <span class="close" onclick="closeFeedbackModal()">&times;</span>
            <h3>💬 Help Us Improve</h3>
            <p>Your feedback helps us make better assessments. How useful was this analysis?</p>

            @if (TempData["FeedbackSubmitted"] != null)
            {
                <div class="alert alert-success">
                    @TempData["FeedbackSubmitted"]
                </div>
            }

            <form method="post" class="feedback-form" id="feedbackForm">
                <input type="hidden" name="targetRole" value="@Model.TargetRole" />
                <input type="hidden" name="score" value="@Model.Analysis.Score" />

                <div class="form-group">
                    <label>Rating (1-5 stars)</label>
                    <div class="rating-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <input type="radio" id="star-@i" name="rating" value="@i" />
                            <label for="star-@i" data-star="@i">&#9733;</label>
                        }
                    </div>
                </div>

                <div class="form-group">
                    <label for="helpful">Was this analysis helpful?</label>
                    <div class="helpful-options">
                        <label><input type="radio" name="helpful" value="true" required /> Yes</label>
                        <label><input type="radio" name="helpful" value="false" required /> No</label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="comments">Comments (optional)</label>
                    <textarea id="comments" name="comments" placeholder="Any suggestions or feedback?" rows="3" maxlength="500"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Submit Feedback</button>
            </form>
        </div>
    </div>

    <!-- CTA -->
    <div class="cta-section">
        <a href="/" class="btn btn-secondary">← Analyze Another Resume</a>
        <button type="button" class="btn btn-outline" onclick="shareResults()">🔗 Share Results</button>
        <a href="?download=true" class="btn btn-primary">📥 Download Report</a>
    </div>
}
else
{
    <div class="alert alert-danger">
        <p>Unable to load analysis results. <a href="/">Try again</a></p>
    </div>
}

<script>
    const resultsSessionId = (() => {
        const fromServer = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.InteractionSessionId ?? string.Empty));
        if (fromServer) {
            sessionStorage.setItem('resumeAnalyzerInteractionSessionId', fromServer);
            return fromServer;
        }

        const existing = sessionStorage.getItem('resumeAnalyzerInteractionSessionId');
        if (existing) {
            return existing;
        }

        const created = crypto.randomUUID ? crypto.randomUUID() : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
        sessionStorage.setItem('resumeAnalyzerInteractionSessionId', created);
        return created;
    })();

    const resultsStart = Date.now();
    const resultsLoggedEvents = new Set();
    const dwellThresholds = [10, 30, 60, 120, 300];
    const scrollThresholds = [25, 50, 75, 100];
    let maxScrollDepth = 0;
    let startStepClicked = false;
    let copiedFirstStep = false;
    let feedbackOpened = false;

    function logResultsInteraction(eventName, details = {}) {
        const payload = JSON.stringify({
            eventName,
            sessionId: resultsSessionId,
            details: {
                secondsOnResults: Math.round((Date.now() - resultsStart) / 1000),
                maxScrollDepth,
                startStepClicked,
                copiedFirstStep,
                feedbackOpened,
                score: @((Model?.Analysis?.Score ?? 0)),
                hasFirstStep: @((Model?.Analysis?.FirstStep != null && !string.IsNullOrWhiteSpace(Model.Analysis.FirstStep.Task)).ToString().ToLowerInvariant()),
                actionPlanCount: @((Model?.Analysis?.ActionPlan?.Count ?? 0)),
                ...details
            }
        });

        if (navigator.sendBeacon) {
            navigator.sendBeacon('/api/interaction-log', new Blob([payload], { type: 'application/json' }));
            return;
        }

        fetch('/api/interaction-log', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: payload,
            keepalive: true
        }).catch(() => {});
    }

    function logResultsOnce(eventName, details = {}) {
        if (resultsLoggedEvents.has(eventName)) {
            return;
        }

        resultsLoggedEvents.add(eventName);
        logResultsInteraction(eventName, details);
    }

    logResultsInteraction('client_results_page_view', {
        viewportWidth: window.innerWidth,
        viewportHeight: window.innerHeight,
        submittedWithFile: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model?.SubmittedWithFile ?? string.Empty))
    });

    dwellThresholds.forEach(seconds => {
        window.setTimeout(() => {
            logResultsOnce(`client_results_dwell_${seconds}s`, { dwellThresholdSeconds: seconds });
        }, seconds * 1000);
    });

    window.addEventListener('scroll', function() {
        const scrollable = Math.max(document.documentElement.scrollHeight - window.innerHeight, 1);
        const depth = Math.min(100, Math.round((window.scrollY / scrollable) * 100));
        maxScrollDepth = Math.max(maxScrollDepth, depth);

        const milestone = scrollThresholds.filter(m => maxScrollDepth >= m).pop() || 0;
        if (milestone > 0) {
            logResultsOnce(`client_results_scroll_${milestone}`, { scrollDepth: maxScrollDepth });
        }
    }, { passive: true });

    document.querySelector('.first-step-actions .btn-primary')?.addEventListener('click', function() {
        startStepClicked = true;
        logResultsInteraction('client_start_step_1_clicked', {
            hrefHost: this.href ? new URL(this.href).host : '',
            taskLength: (document.getElementById('first-step-task-text')?.textContent || '').trim().length
        });
    });

    document.querySelector('.cta-section .btn-secondary')?.addEventListener('click', function() {
        logResultsInteraction('client_analyze_another_clicked');
    });

    document.querySelector('.cta-section a[href="?download=true"]')?.addEventListener('click', function() {
        logResultsInteraction('client_download_report_clicked');
    });
    function firstStepMicroFeedback(useful) {
        const el = document.getElementById('first-step-micro-msg');
        if (!el) return;
        el.hidden = false;
        logResultsInteraction('client_first_step_micro_feedback', { useful });
        el.textContent = useful ? 'Thanks—that helps us tune suggestions.' : 'Thanks—we\'ll keep improving.';
    }

    function copyFirstStepTask() {
        const el = document.getElementById('first-step-task-text');
        if (!el) return;
        const text = (el.textContent || '').trim();
        if (!text) return;
        copiedFirstStep = true;
        logResultsInteraction('client_first_step_copied', { taskLength: text.length });

        if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(text).then(() => {
                alert('Task copied to clipboard.');
            }).catch(() => fallbackCopy(text));
        } else {
            fallbackCopy(text);
        }
    }

    function fallbackCopy(text) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.left = '-9999px';
        document.body.appendChild(textArea);
        textArea.select();
        try {
            document.execCommand('copy');
            alert('Task copied to clipboard.');
        } catch {
            alert('Could not copy automatically. Select the task text and copy manually.');
        }
        document.body.removeChild(textArea);
    }

    function shareResults() {
        logResultsInteraction('client_share_results_clicked');
        const title = `Resume Analysis for ${document.querySelector('.results-header strong').textContent}`;
        const text = `Check out my resume analysis score: ${document.querySelector('.score-number').textContent}/100 for ${document.querySelector('.results-header strong').textContent}`;
        const url = window.location.href;

        if (navigator.share) {
            // Use Web Share API for mobile
            navigator.share({
                title: title,
                text: text,
                url: url
            }).catch(console.error);
        } else {
            // Fallback: copy to clipboard
            navigator.clipboard.writeText(`${title}\n${text}\n${url}`).then(() => {
                alert('Results link copied to clipboard!');
            }).catch(() => {
                // Fallback for older browsers
                const textArea = document.createElement('textarea');
                textArea.value = `${title}\n${text}\n${url}`;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                document.body.removeChild(textArea);
                alert('Results link copied to clipboard!');
            });
        }
    }

    function openFeedbackModal() {
        feedbackOpened = true;
        logResultsInteraction('client_feedback_opened');
        document.getElementById('feedbackModal').style.display = 'block';
    }

    function closeFeedbackModal() {
        logResultsInteraction('client_feedback_closed');
        document.getElementById('feedbackModal').style.display = 'none';
    }

    // Close modal when clicking outside
    window.onclick = function(event) {
        const modal = document.getElementById('feedbackModal');
        if (event.target == modal) {
            modal.style.display = 'none';
        }
    }

    // Star rating functionality
    const ratingStars = document.querySelectorAll('.rating-stars input');
    const ratingLabels = document.querySelectorAll('.rating-stars label');

    ratingLabels.forEach(label => {
        label.addEventListener('mouseenter', function() {
            const starValue = parseInt(this.dataset.star);
            ratingLabels.forEach(l => {
                const lValue = parseInt(l.dataset.star);
                if (lValue <= starValue) {
                    l.style.color = '#fbbf24';
                } else {
                    l.style.color = 'var(--gray-300)';
                }
            });
        });

        label.addEventListener('mouseleave', function() {
            updateStarColors();
        });

        label.addEventListener('click', function() {
            const starValue = parseInt(this.dataset.star);
            document.getElementById(`star-${starValue}`).checked = true;
            logResultsInteraction('client_feedback_rating_selected', { rating: starValue });
            updateStarColors();
        });
    });

    function updateStarColors() {
        const checkedInput = document.querySelector('.rating-stars input:checked');
        ratingLabels.forEach(label => {
            const starValue = parseInt(label.dataset.star);
            if (checkedInput && parseInt(checkedInput.value) >= starValue) {
                label.style.color = '#fbbf24';
            } else {
                label.style.color = 'var(--gray-300)';
            }
        });
    }

    document.querySelectorAll('input[name="helpful"]').forEach(input => {
        input.addEventListener('change', function() {
            logResultsInteraction('client_feedback_helpful_selected', { helpful: this.value === 'true' });
        });
    });

    document.getElementById('comments')?.addEventListener('input', function() {
        const length = this.value.trim().length;
        if (length > 0) {
            logResultsOnce('client_feedback_comment_started', { commentLength: length });
        }
    });

    document.getElementById('feedbackForm')?.addEventListener('submit', function() {
        const checkedRating = document.querySelector('.rating-stars input:checked');
        const checkedHelpful = document.querySelector('input[name="helpful"]:checked');
        logResultsInteraction('client_feedback_submit_attempted', {
            rating: checkedRating ? parseInt(checkedRating.value) : 0,
            helpful: checkedHelpful ? checkedHelpful.value === 'true' : null,
            commentLength: document.getElementById('comments')?.value.trim().length || 0
        });
    });

    // Call updateStarColors on page load to ensure correct initial state
    document.addEventListener('DOMContentLoaded', updateStarColors);

    document.addEventListener('visibilitychange', function() {
        if (document.visibilityState === 'hidden') {
            logResultsInteraction('client_results_page_hidden', {
                leftWithoutStartingStep1: !startStepClicked,
                finalScrollDepth: maxScrollDepth
            });
        }
    });
</script>
